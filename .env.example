# Development Environment Variables
# Copy this file to .env and configure for your local environment

# Development environment (dev, staging, prod)
DENORMALIZER_ENV=dev

# Trino Connection
TRINO_HOST=localhost
TRINO_PORT=443
TRINO_USER=admin
TRINO_PASSWORD=password

# Optional: AWS Secrets Manager (for loading passwords)
# AWS_REGION=us-east-1
# AWS_PROFILE=default
